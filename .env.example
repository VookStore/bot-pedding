# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DEVELOPER_GUILD_ID=your_developer_guild_id_here
BOT_FOUNDER_IDS=123456789012345678,876543210987654321

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vook_tickets?schema=public

# Optional Redis Configuration
# If provided, Redis will be used for locking and rate limits. If omitted, in-memory Map locks are used.
REDIS_URL=redis://localhost:6379

# Transcript Storage Mode: local or s3
TRANSCRIPT_STORAGE_MODE=local
TRANSCRIPT_LOCAL_PATH=/data/transcripts

# Optional Cloudflare R2 / S3 Credentials (Required if TRANSCRIPT_STORAGE_MODE=s3)
S3_ENDPOINT=https://your-r2-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=vook-transcripts
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_PUBLIC_BASE_URL=https://transcripts.vook.com

# Logger and Node Environment
LOG_LEVEL=info
NODE_ENV=development
