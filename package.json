{
  "name": "vook-ticket-bot",
  "version": "1.0.0",
  "description": "Professional Discord Ticket Bot with Components V2, TypeScript, Prisma, and PostgreSQL",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "commands:deploy": "ts-node scripts/deploy-commands.ts",
    "commands:delete": "ts-node scripts/delete-commands.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "discord.js",
    "discord-bot",
    "ticket",
    "components-v2",
    "prisma",
    "postgresql",
    "typescript"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@prisma/client": "^5.16.0",
    "discord.js": "^14.19.0",
    "dotenv": "^16.4.5",
    "pino": "^9.2.0",
    "redis": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2",
    "prisma": "^5.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
